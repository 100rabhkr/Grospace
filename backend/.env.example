# Supabase (use SERVICE ROLE key for backend - has admin access)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJhbGci...your-service-role-key

# Google Gemini (for document extraction, classification, Q&A)
GEMINI_API_KEY=your-gemini-api-key

# Google Cloud Vision (for OCR — paste the full service account JSON as a single line)
GOOGLE_CLOUD_CREDENTIALS_JSON={"type":"service_account","project_id":"...","private_key_id":"...","private_key":"...","client_email":"...","client_id":"...","auth_uri":"...","token_uri":"...","auth_provider_x509_cert_url":"...","client_x509_cert_url":"..."}

# Google Sheets Integration
GOOGLE_SHEETS_SPREADSHEET_ID=your-spreadsheet-id
GOOGLE_SHEETS_CREDENTIALS_JSON={"type":"service_account",...}

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:3000

# Port (Railway sets this automatically)
PORT=8000
